# renovate: datasource=docker depName=golang
ARG GO_VERSION=1.26
# renovate: datasource=docker depName=registry.access.redhat.com/ubi9/ubi-minimal
ARG UBI_VERSION=9.6

FROM golang:${GO_VERSION} AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY cmd/ ./cmd/
COPY internal/ ./internal/

ARG TARGETOS=linux
ARG TARGETARCH=amd64
ARG VERSION=dev
# PRODUCT_NAME overrides the compiled-in brand. Leave empty to keep the
# default baked into internal/branding.
ARG PRODUCT_NAME=
# The single quotes inside -ldflags are passed verbatim to the Go linker so a
# PRODUCT_NAME containing spaces stays a single -X argument; ${PRODUCT_NAME}
# still expands because the surrounding -ldflags value is double-quoted.
# hadolint ignore=SC2016
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -trimpath \
    -ldflags="-s -w -X main.version=${VERSION}${PRODUCT_NAME:+ -X 'github.com/slauger/alertmanager-graph-bridge/internal/branding.ProductName=${PRODUCT_NAME}'}" \
    -o /out/alertmanager-graph-bridge ./cmd/alertmanager-graph-bridge

FROM registry.access.redhat.com/ubi9/ubi-minimal:${UBI_VERSION}

LABEL org.opencontainers.image.title="alertmanager-graph-bridge" \
      org.opencontainers.image.description="Bridge between Prometheus Alertmanager and the Microsoft Graph API" \
      org.opencontainers.image.source="https://github.com/slauger/alertmanager-graph-bridge" \
      org.opencontainers.image.licenses="Apache-2.0"

COPY --from=builder /out/alertmanager-graph-bridge /usr/local/bin/alertmanager-graph-bridge
COPY config.yaml /etc/alertmanager-graph-bridge/config.yaml

USER 1001:0

EXPOSE 8080

ENTRYPOINT ["/usr/local/bin/alertmanager-graph-bridge"]
CMD ["-config", "/etc/alertmanager-graph-bridge/config.yaml"]
